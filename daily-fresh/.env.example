# daily.dev API (required)
DAILY_DEV_PAT=dda_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# self-hosted LLM (optional, unused in MVP)
OPENAI_URL=https://your-llm-endpoint/v1
OPENAI_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=your-model-name

# server
PORT=3737
BASE_URL=http://localhost:3737

# storage
DB_PATH=./data/daily-fresh.db
REDIS_URL=redis://localhost:6379

# logging
LOG_LEVEL=info

# self-imposed rate limit (provider allows 60/min)
RATE_LIMIT_RPM=50

# secret for signing the df_handle cookie (rotate in production)
COOKIE_SECRET=replace-with-32-bytes-base64-output-of-openssl-rand
